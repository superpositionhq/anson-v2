# slack-bridge environment — copy to .env and fill in.
# Anson Stage D writes this file from your interview answers.
# Manual setup: see references/slack_app.md for Slack app + token instructions.

# Bot token (xoxb-*) — outbound chat.postMessage, reactions, etc.
SLACK_BOT_TOKEN=xoxb-...

# App token (xapp-*) — Socket Mode connection
SLACK_APP_TOKEN=xapp-...

# Workspace dir Claude runs in (loads CLAUDE.md, resolves skills/).
# Optional — config.py reads $WORKSPACE_ROOT from the process env first; this
# fallback only matters if the daemon is launched without WORKSPACE_ROOT set.
# Use a literal absolute path here (dotenv does not expand ${VAR}).
# SLACK_BRIDGE_WORKSPACE=/Users/you/Assistant

# Path to the claude CLI binary
CLAUDE_BIN=claude

# Log level: DEBUG | INFO | WARNING | ERROR
SLACK_BRIDGE_LOG_LEVEL=INFO

# Per-message claude subprocess timeout (seconds); 0 disables the limit
SLACK_BRIDGE_CLAUDE_TIMEOUT=0

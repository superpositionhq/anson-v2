#!/usr/bin/env python3
"""
Fetch Slack messages from the last N hours across the user's critical channels.
Generated by anson-v2 for {{USER_PREFERRED_NAME}}.

Requires SLACK_XOXC_TOKEN and SLACK_XOXD_TOKEN in {{WORKSPACE_ROOT}}/.env.
"""
import argparse
import json
import os
import sys
import time
from pathlib import Path

import requests

WORKSPACE = Path("{{WORKSPACE_ROOT}}")


def load_env() -> dict[str, str]:
    env_path = WORKSPACE / ".env"
    env: dict[str, str] = {}
    for line in env_path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        env[k.strip()] = v.strip().strip('"').strip("'")
    return env


def fetch_channel(channel_id: str, oldest: float, xoxc: str, xoxd: str) -> list[dict]:
    r = requests.get(
        "https://slack.com/api/conversations.history",
        params={"channel": channel_id, "oldest": oldest, "limit": 200},
        headers={
            "Authorization": f"Bearer {xoxc}",
            "Cookie": f"d={xoxd}",
        },
        timeout=30,
    )
    r.raise_for_status()
    data = r.json()
    if not data.get("ok"):
        print(f"slack error on {channel_id}: {data.get('error')}", file=sys.stderr)
        return []
    return data.get("messages", [])


def main() -> None:
    ap = argparse.ArgumentParser()
    ap.add_argument("--since-hours", type=int, default=8)
    ap.add_argument("--channels", required=True, help="comma-separated channel IDs")
    args = ap.parse_args()

    env = load_env()
    xoxc = env.get("SLACK_XOXC_TOKEN")
    xoxd = env.get("SLACK_XOXD_TOKEN")
    if not xoxc or not xoxd:
        sys.exit("missing SLACK_XOXC_TOKEN / SLACK_XOXD_TOKEN in .env")

    oldest = time.time() - (args.since_hours * 3600)

    out = {}
    for cid in [c.strip() for c in args.channels.split(",") if c.strip()]:
        out[cid] = fetch_channel(cid, oldest, xoxc, xoxd)

    json.dump(out, sys.stdout, indent=2)


if __name__ == "__main__":
    main()
